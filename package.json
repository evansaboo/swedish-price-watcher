  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "apify-client": "^2.23.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.6.0",
    "fastify": "^5.8.5",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rebrowser-playwright": "^1.52.0",
    "robots-parser": "^3.0.1",
    "undici": "^8.1.0"
  }
