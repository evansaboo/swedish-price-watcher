# Port the web UI listens on
PORT=3000

# Bind to all interfaces (required for Docker / reverse proxy)
HOST=0.0.0.0

DATA_FILE=data/store.json
SOURCES_FILE=config/sources.json

# Run a scan immediately on startup
RUN_ON_START=true

# Default interval between full scans (minutes); overridable per-source
SCAN_INTERVAL_MINUTES=180

HOST_DELAY_MS=8000
REQUEST_TIMEOUT_MS=20000
MAX_HISTORY_ENTRIES=20
USER_AGENT=swedish-price-watcher/0.1 (+you@example.com)

# --- Scraping services (optional) ---
APIFY_TOKEN=
APIFY_TOKEN_2=
APIFY_TOKEN_3=
APIFY_STATE_STORE_NAME=swedish-price-watcher-state
APIFY_STATE_RECORD_KEY=state
SCRAPFLY_API_KEY=

# FlareSolverr URL — set automatically by docker-compose; override here for local dev
# FLARESOLVERR_URL=http://localhost:8191

# --- Cloudflare Tunnel (for public access via your domain) ---
# Create tunnel: cloudflared tunnel create price-watcher
# Then add DNS route: cloudflared tunnel route dns price-watcher price-watcher.evansaboo.com
CLOUDFLARE_TUNNEL_TOKEN=

# --- Notifications ---
DISCORD_WEBHOOK_URL=
NOTIFICATION_COOLDOWN_HOURS=24
DISABLE_HOURS_ON_BLOCK=12

# --- Deal filters ---
MINIMUM_SCORE=65
MINIMUM_DISCOUNT_PERCENT=10
MINIMUM_PROFIT_SEK=50

# --- Resale-model LLM classifier (deterministic-first; LLM only fills the tail) ---
# Provider: "gemini" (hosted, needs an API key, free tier ~20 req/min) or
#           "ollama" (LOCAL model, no key, no cost, no rate limit — slower per call).
LLM_CLASSIFIER_ENABLED=true
LLM_PROVIDER=gemini
# Gemini provider:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Ollama provider (run `ollama serve`; pull a model first, e.g. `ollama pull qwen2.5:3b`):
#   qwen2.5:3b — best quality/speed balance on a Raspberry Pi 4 (8GB).
#   qwen2.5:1.5b — ~2x faster, lower quality.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
# Bound work per enrichment run (local inference is slow; results are cached):
LLM_MAX_TITLES_PER_RUN=400
LLM_REQUEST_TIMEOUT_MS=30000
